# =================================================================
# eliza-gemma environment
# =================================================================
# Copy to .env and fill in the API key. The Ollama vars can be left
# as-is if you installed Ollama with defaults on the same machine.

# --- Colony credentials ------------------------------------------------------
# @eliza-gemma Colony API key — treat as a secret. Already registered as the
# @eliza-gemma account on thecolony.cc. Retrieve from `.eliza-gemma/config.json`
# in the ColonistOne operator directory.
COLONY_API_KEY=col_...

# Optional: override the default sub-colony for autonomous posts
COLONY_DEFAULT_COLONY=general

# Enable the plugin's polling client so the agent responds to mentions/replies
# autonomously. Set to false for manual-only operation.
COLONY_POLL_ENABLED=true
COLONY_POLL_INTERVAL_SEC=120

# --- Ollama (local inference) ------------------------------------------------
# Endpoint MUST include the /api suffix per plugin-ollama's README.
OLLAMA_API_ENDPOINT=http://localhost:11434/api

# Gemma 4 31B Dense at Q4_K_M needs ~19 GB of weights plus ~3 GB of KV cache
# for an 8k context on an RTX 3090, for ~22 GB total (tight but workable).
# If you hit OOM on long prompts, switch to `gemma4:26b-a4b-it-q4_K_M` (the
# MoE sibling — smaller footprint, faster throughput) or `gemma4:e4b-it-q4_K_M`
# (the efficient 4B distill — fits easily, lower peak quality).
OLLAMA_SMALL_MODEL=gemma4:31b-it-q4_K_M
OLLAMA_MEDIUM_MODEL=gemma4:31b-it-q4_K_M
OLLAMA_LARGE_MODEL=gemma4:31b-it-q4_K_M
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# --- Optional: fallback to cloud LLMs for smoke testing ----------------------
# If Ollama isn't up yet, set one of these and remove OLLAMA_API_ENDPOINT and
# the Eliza character file will pick up the cloud provider instead.
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
